@model SmartHotel.UI.DTOs.Room.RoomResponse

@{
    ViewData["Title"] = "Chi tiết Phòng " + Model.RoomNumber;
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h6 class="mb-0">Thông tin chi tiết phòng</h6>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fa fa-arrow-left me-2"></i>Quay lại
                    </a>
                </div>

                <div class="row">
                    <div class="col-md-5">
                        <div class="card shadow-sm border-0">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="card-img-top rounded" alt="Hình ảnh phòng @Model.RoomNumber"
                                     style="height: 350px; object-fit: cover;"
                                     onerror="this.src='https://via.placeholder.com/400x300?text=No+Image'" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center bg-secondary rounded" style="height: 350px;">
                                    <span class="text-white"><i class="fa fa-image fa-3x"></i><br>Không có ảnh</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-md-7">
                        <div class="table-responsive">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <th style="width: 30%">Số phòng:</th>
                                        <td><h4 class="text-primary m-0">@Model.RoomNumber</h4></td>
                                    </tr>
                                    <tr>
                                        <th>Trạng thái:</th>
                                        <td>
                                            @if (Model.Status == "Available")
                                            {
                                                <span class="badge bg-success">@Model.StatusVietnamese</span>
                                            }
                                            else if (Model.Status == "Occupied")
                                            {
                                                <span class="badge bg-danger">@Model.StatusVietnamese</span>
                                            }
                                            else if (Model.Status == "Maintenance")
                                            {
                                                <span class="badge bg-warning text-dark">@Model.StatusVietnamese</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@Model.StatusVietnamese</span>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Giá thuê:</th>
                                        <td class="fs-5 fw-bold text-success">@Model.Price.ToString("N0") VNĐ</td>
                                    </tr>
                                    <tr>
                                        <th>Tầng:</th>
                                        <td>@Model.Floor</td>
                                    </tr>
                                    <tr>
                                        <th>Sức chứa:</th>
                                        <td>@Model.Capacity người</td>
                                    </tr>
                                    <tr>
                                        <th>Mô tả:</th>
                                        <td class="text-muted">
                                            @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả" : Model.Description)
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4">
                            <a asp-action="Edit" asp-route-id="@Model.RoomId" class="btn btn-primary me-2">
                                <i class="fa fa-edit me-2"></i>Chỉnh sửa
                            </a>

                            <form asp-action="Delete" asp-route-id="@Model.RoomId" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa phòng này không?');">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fa fa-trash me-2"></i>Xóa phòng
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>