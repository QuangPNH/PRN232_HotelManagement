@using SmartHotel.UI.DTOs
@model PagedResult<SmartHotel.UI.DTOs.Room.RoomResponse>

@{
    ViewData["Title"] = "Quản lý Phòng";
      var hasPrevious = Model.PageIndex > 1;
    var hasNext = Model.PageIndex < Model.TotalPages;

    var roomNumber = Context.Request.Query["roomNumber"].ToString();
    var status = Context.Request.Query["status"].ToString();
    var capacity = Context.Request.Query["capacity"].ToString();
    var floor = Context.Request.Query["floor"].ToString();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fa fa-exclamation-triangle me-2"></i>@TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="col-12">
    <div class="bg-light rounded h-100 p-4">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <h6 class="mb-0">Danh sách Phòng</h6>
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">
                <i class="fa fa-plus me-2"></i>Thêm Phòng
            </a>
        </div>
        <form method="get" asp-action="Index" class="row g-3 mb-3">

            <div class="col-md-2">
                <input type="text" name="roomNumber"
                       value="@Context.Request.Query["roomNumber"]"
                       class="form-control form-control-sm"
                       placeholder="Tìm số phòng..." />
            </div>

            <div class="col-md-2">
              

<select name="status" class="form-select form-select-sm">
    <option value="">-- Trạng thái --</option>

    <option value="Available"
            selected="@(status == "Available")">
        Phòng Trống
    </option>

    <option value="Occupied"
            selected="@(status == "Occupied")">
        Đang sử dụng
    </option>

    <option value="Maintenance"
            selected="@(status == "Maintenance")">
        Phòng Bảo trì
    </option>

    <option value="Cleaning"
            selected="@(status == "Cleaning")">
        Đang dọn dẹp
    </option>
</select>
            </div>

            <div class="col-md-2">
                <input type="number" name="capacity"
                       value="@Context.Request.Query["capacity"]"
                       class="form-control form-control-sm"
                       placeholder="Sức chứa" />
            </div>

            <div class="col-md-2">
                <input type="number" name="floor"
                       value="@Context.Request.Query["floor"]"
                       class="form-control form-control-sm"
                       placeholder="Tầng" />
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="fa fa-search me-1"></i> Lọc
                </button>
                <a href="@Url.Action("Index")" class="btn btn-sm btn-secondary">
                    Reset
                </a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table text-start align-middle">
                <thead>
                    <tr>
                        <th scope="col">#ID</th>
                        <th scope="col">Phòng</th>
                        <th scope="col">Tầng</th>
                        <th scope="col">Sức chứa</th>
                        <th scope="col">Giá (VNĐ)</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <th scope="row">@item.RoomId</th>
                                <td class="fw-bold">@item.RoomNumber</td>
                                <td>@item.Floor</td>
                                <td>@item.Capacity người</td>
                                <td>@item.Price.ToString("N0")</td>
                                <td>
                                    @if (item.Status == "Available")
                                    {
                                        <span class="badge bg-success">@item.StatusVietnamese</span>
                                    }
                                    else if (item.Status == "Occupied")
                                    {
                                        <span class="badge bg-danger">@item.StatusVietnamese</span>
                                    }
                                    else if (item.Status == "Maintenance")
                                    {
                                        <span class="badge bg-warning text-dark">@item.StatusVietnamese</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.StatusVietnamese</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = item.RoomId })"
                                       class="btn btn-sm btn-link text-info">
                                        <i class="fa fa-eye"></i> View
                                    </a>

                                    <a href="@Url.Action("Edit", new { id = item.RoomId })"
                                       class="btn btn-sm btn-link text-primary">
                                        <i class="fa fa-edit me-1"></i> Edit
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm btn-link text-danger"
                                            onclick="openDeleteRoomModal(@item.RoomId, '@item.RoomNumber')">
                                        <i class="fa fa-trash me-1"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                Không có dữ liệu.
                            </td>
                        </tr>
                    }
                </tbody>


            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-between align-items-center mt-4">

    <span class="text-muted small">
        Hiển thị <strong>@Model.Items.Count()</strong> / 
        <strong>@Model.TotalCount</strong> bản ghi
    </span>

    <nav>
        <ul class="pagination pagination-sm mb-0">

            <!-- Previous -->
            <li class="page-item @(hasPrevious ? "" : "disabled")">
                <a class="page-link"
                   href="@Url.Action("Index", new {
                        pageIndex = Model.PageIndex - 1,
                        pageSize = Model.PageSize,
                        roomNumber = roomNumber,
                        status  = status ,
                        capacity = capacity,
                        floor = floor
                   })">
                    &laquo; Trước
                </a>
            </li>

            <!-- Page numbers -->
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link"
                       href="@Url.Action("Index", new {
                            pageIndex = i,
                            pageSize = Model.PageSize,
                            roomNumber = roomNumber,
                            status  = status,
                            capacity = capacity,
                            floor = floor
                       })">
                        @i
                    </a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(hasNext ? "" : "disabled")">
                <a class="page-link"
                   href="@Url.Action("Index", new {
                        pageIndex = Model.PageIndex + 1,
                        pageSize = Model.PageSize,
                        roomNumber = roomNumber,
                        status  = status ,
                        capacity = capacity,
                        floor = floor
                   })">
                    Sau &raquo;
                </a>
            </li>

        </ul>
    </nav>
</div>
<!-- Delete Room Modal -->
<div class="modal fade" id="deleteRoomModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Xác nhận xóa phòng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc chắn muốn xóa phòng
                <strong id="roomNameToDelete"></strong> không?
            </div>
            <div class="modal-footer">
                <form id="deleteRoomForm" method="post">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteRoomModal(roomId, roomNumber) {

            // Set tên phòng vào modal
            document.getElementById("roomNameToDelete").innerText = roomNumber;

            // Set action form
            var form = document.getElementById("deleteRoomForm");
            form.action = "/Room/Delete/" + roomId;

            // Show modal
            var modal = new bootstrap.Modal(document.getElementById('deleteRoomModal'));
            modal.show();
        }
    </script>
}
