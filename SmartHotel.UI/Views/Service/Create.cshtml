@model SmartHotel.UI.DTOs.Service.CreateServiceRequest

@{
    ViewData["Title"] = "Thêm Dịch vụ mới";
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-sm-12 col-xl-8 mx-auto">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4 text-primary"><i class="fa fa-plus-circle me-2"></i>Thêm Dịch vụ Mới</h6>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="ServiceName" class="form-label">Tên dịch vụ <span class="text-danger">*</span></label>
                        <input asp-for="ServiceName" class="form-control" placeholder="Ví dụ: Điện sinh hoạt, Nước sạch, Wifi..." />
                        <span asp-validation-for="ServiceName" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="UnitPrice" class="form-label">Đơn giá (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="UnitPrice" type="number" class="form-control" placeholder="Nhập số tiền..." />
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Unit" class="form-label">Đơn vị tính <span class="text-danger">*</span></label>
                            <select asp-for="Unit" class="form-select">
                                <option value="">-- Chọn đơn vị --</option>
                                <option value="kWh">kWh (Điện)</option>
                                <option value="m3">m3 (Nước)</option>
                                <option value="Tháng">Tháng</option>
                                <option value="Người">Người</option>
                                <option value="Lần">Lần</option>
                                <option value="Cái">Cái</option>
                            </select>
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch p-3 border rounded bg-white">
                            <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="IsMeterBased" id="meterSwitch">
                            <label class="form-check-label fw-bold" for="meterSwitch">
                                Tính tiền theo chỉ số đồng hồ (Điện/Nước)
                            </label>
                            <div class="form-text mt-1 ms-1">
                                <small>Bật tùy chọn này nếu dịch vụ cần ghi chỉ số <strong>Cũ - Mới</strong> hàng tháng.</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-primary"><i class="fa fa-save me-2"></i>Lưu Dịch vụ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}