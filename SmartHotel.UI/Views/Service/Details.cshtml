@model SmartHotel.UI.DTOs.Service.ServiceResponse

@{
    ViewData["Title"] = "Chi tiết Dịch vụ";
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-sm-12 col-xl-6 mx-auto">
            <div class="bg-light rounded h-100 p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="text-primary mb-0">
                        <i class="fa fa-info-circle me-2"></i>Thông tin chi tiết
                    </h6>
                    <span class="badge bg-success">Đang hoạt động</span>
                </div>

                <div class="text-center mb-4 p-3 border rounded bg-white">
                    <h4 class="text-dark mb-1">@Model.ServiceName</h4>
                    <small class="text-muted">Mã dịch vụ: #@Model.ServiceId</small>
                </div>

                <dl class="row">
                    <dt class="col-sm-5 text-muted">Đơn giá hiện tại:</dt>
                    <dd class="col-sm-7 fw-bold text-danger">
                        @Model.UnitPrice.ToString("N0") VNĐ
                    </dd>

                    <dt class="col-sm-5 text-muted">Đơn vị tính:</dt>
                    <dd class="col-sm-7">
                        1 @Model.Unit
                    </dd>

                    <dt class="col-sm-5 text-muted">Phương thức tính phí:</dt>
                    <dd class="col-sm-7">
                        @if (Model.IsMeterBased)
                        {
                            <span class="badge bg-info text-dark">
                                <i class="fa fa-tachometer-alt me-1"></i>Theo chỉ số đồng hồ
                            </span>
                            <div class="small text-muted mt-1">(Cần ghi chỉ số cũ/mới hàng tháng)</div>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="fa fa-box me-1"></i>Trọn gói / Cố định
                            </span>
                            <div class="small text-muted mt-1">(Tính tiền cố định theo số lượng)</div>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-5 text-muted">Mô tả thêm:</dt>
                        <dd class="col-sm-7">@Model.Description</dd>
                    }
                </dl>

                <hr />

                <div class="d-flex justify-content-center gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fa fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.ServiceId" class="btn btn-primary">
                        <i class="fa fa-edit me-2"></i>Chỉnh sửa
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>