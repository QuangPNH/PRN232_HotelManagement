@model SmartHotel.UI.DTOs.Invoice.InvoiceResponse

@{
    ViewData["Title"] = $"Chi tiết Hóa đơn INV-{Model.InvoiceId}";
}

<div class="container-fluid pt-4 px-4">
    <div class="row">
        <div class="col-12 col-xl-10 offset-xl-1">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <a href="@Url.Action("Dashboard")" class="btn btn-secondary btn-sm">
                    <i class="fa fa-arrow-left me-2"></i>Quay lại Tổng quan
                </a>
                <button onclick="window.print()" class="btn btn-info btn-sm text-white">
                    <i class="fa fa-print me-2"></i>In / Lưu PDF
                </button>
            </div>

            <div class="bg-white rounded shadow-sm p-5" id="invoice-print-area">
                <div class="row border-bottom pb-4 mb-4">
                    <div class="col-sm-6">
                        <h3 class="text-primary mb-0"><i class="fa fa-building me-2"></i>SmartHotel</h3>
                        <p class="mb-0 text-muted small mt-1">Hóa đơn tiền phòng & Dịch vụ</p>
                    </div>
                    <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
                        <h5 class="mb-1 fw-bold">MÃ HĐ: INV-@Model.InvoiceId</h5>
                        <p class="mb-0 text-muted">Kỳ thu: <strong>Tháng @Model.InvoiceMonth.ToString("MM/yyyy")</strong></p>
                        <p class="mb-0">
                            @if (Model.IsPaid)
                            {
                                <span class="badge bg-success fs-6"><i class="fa fa-check me-2"></i>ĐÃ THANH TOÁN</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark fs-6"><i class="fa fa-clock me-2"></i>CHƯA THANH TOÁN</span>
                            }
                        </p>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-sm-6">
                        <h6 class="fw-bold mb-2">Thông tin Phòng:</h6>
                        <div><strong>Phòng:</strong> @Model.RoomNumber</div>
                        <div><strong>Mã Hợp đồng:</strong> #@Model.ContractId</div>
                    </div>
                </div>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="text-center" style="width: 50px;">STT</th>
                                <th scope="col">Khoản thu / Dịch vụ</th>
                                <th scope="col" class="text-center">Số lượng</th>
                                <th scope="col" class="text-end">Đơn giá</th>
                                <th scope="col" class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.InvoiceDetails != null && Model.InvoiceDetails.Any())
                            {
                                int stt = 1;
                                foreach (var detail in Model.InvoiceDetails)
                                {
                                    <tr>
                                        <td class="text-center">@(stt++)</td>
                                        <td>@detail.ServiceName</td>
                                        <td class="text-center">@detail.Quantity</td>
                                        <td class="text-end">@detail.UnitPrice.ToString("N0")</td>
                                        <td class="text-end fw-bold">@detail.Amount.ToString("N0")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end fs-5">TỔNG CỘNG CẦN THANH TOÁN:</th>
                                <th class="text-end fs-4 text-danger fw-bold">@Model.TotalAmount.ToString("N0") đ</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (!Model.IsPaid)
                {
                    <div class="alert alert-info mt-4 d-print-none">
                        <h6 class="fw-bold text-info"><i class="fa fa-university me-2"></i>HƯỚNG DẪN THANH TOÁN CHUYỂN KHOẢN</h6>
                        <div class="row mt-3">
                            <div class="col-md-8">
                                <ul class="list-unstyled mb-0">
                                    <li class="mb-2"><strong>Ngân hàng:</strong> Vietcombank (VCB)</li>
                                    <li class="mb-2"><strong>Chủ tài khoản:</strong> NGUYEN VAN A (QUAN LY KHACH SAN)</li>
                                    <li class="mb-2"><strong>Số tài khoản:</strong> <span class="fs-5 fw-bold text-danger">0123456789</span></li>
                                    <li><strong>Nội dung CK:</strong> <span class="text-primary fw-bold">Thanh toan HD INV-@Model.InvoiceId Phong @Model.RoomNumber</span></li>
                                </ul>
                            </div>
                            <div class="col-md-4 text-center">
                                <img src="https://img.vietqr.io/image/vcb-0123456789-compact2.png?amount=@Model.TotalAmount&addInfo=Thanh toan HD INV-@Model.InvoiceId Phong @Model.RoomNumber" alt="QR Code" class="img-fluid border p-1 rounded" style="max-height: 150px;" />
                                <p class="small text-muted mt-2">Quét mã để thanh toán nhanh</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            body * {
                visibility: hidden;
            }

            #invoice-print-area, #invoice-print-area * {
                visibility: visible;
            }

            #invoice-print-area {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                box-shadow: none !important;
            }

            .d-print-none {
                display: none !important;
            }
        }
    </style>
}